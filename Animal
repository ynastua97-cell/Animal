public  class Animal {
    int id;
    String name;
    String bDay;

    Animal(int id, String name, String bDay) {
        this.bDay = bDay;
        this.id = id;
        this.name = name;
    }

    Animal ()
    {

    }

    public void printInfo()
    {
        System.out.println("Имя животного: " +name +  ", id животного: "+ id + ", день рождения животного: " + bDay + ".");
    }
}


